# PesaPal Sandbox Credentials
# Get these from https://cybqa.pesapal.com/ (sandbox merchant account)
PESAPAL_CONSUMER_KEY=your_sandbox_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_sandbox_consumer_secret_here
# PesaPal v3 API base URL (sandbox)
PESAPAL_API_URL=https://cybqa.pesapal.com/pesapalv3/api
# Your Netlify site URL (for IPN callback; use your deployed domain)
SITE_URL=https://yovibe.net
# IPN Notification ID - after registering IPN (run register-ipn function once)
PESAPAL_NOTIFICATION_ID=your_ipn_notification_id_here

# Note: For production, use:
# PESAPAL_API_URL=https://pay.pesapal.com/v3/api
# SITE_URL=https://yourproductiondomain.com
