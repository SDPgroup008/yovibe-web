# PesaPal API Credentials (from your PesaPal business account)
# Get these from: PesaPal Dashboard → Settings → API → Sandbox/Live credentials
PESAPAL_CONSUMER_KEY=your_sandbox_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_sandbox_consumer_secret_here
PESAPAL_API_URL=https://cybqa.pesapal.com/api
PESAPAL_BASE_URL=https://cybqa.pesapal.com

# Note: For production, use the live credentials and update URLs accordingly:
# PESAPAL_API_URL=https://www.pesapal.com/api
# PESAPAL_BASE_URL=https://www.pesapal.com
